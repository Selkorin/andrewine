---
interface Props {
  root?: string;
}

const { root = '../' } = Astro.props;
---

<header class="article-site-header" data-site-chrome="header">
  <a class="article-brand" href={root} aria-label="Andrewine — на главную">
    <svg viewBox="0 0 42 52" aria-hidden="true"><path d="M21 2c2 7 0 12-5 17M22 9c6-5 13-5 19-1-5 5-11 7-18 6M18 14C12 10 6 11 2 15c5 4 10 5 16 3" fill="none" stroke="currentColor" stroke-width="1.5"/><g fill="currentColor"><circle cx="20" cy="23" r="4"/><circle cx="13" cy="28" r="4"/><circle cx="27" cy="29" r="4"/><circle cx="20" cy="34" r="4"/><circle cx="31" cy="36" r="3.5"/><circle cx="15" cy="39" r="3.5"/><circle cx="22" cy="44" r="3.5"/><circle cx="22" cy="50" r="2"/></g></svg>
    <span>ANDREWINE</span>
  </a>
  <nav aria-label="Основная навигация">
    <a href={`${root}buy_wine/`}>Вино</a>
    <a href={`${root}buy_whisky/`}>Виски</a>
    <a href={`${root}buy_cognac/`}>Коньяк</a>
    <a href={`${root}buy_champagne/`}>Шампанское</a>
    <a href={`${root}articles/`}>Статьи</a>
  </nav>
  <a class="article-header__cta" href="https://t.me/AWONLINE_BOT" rel="noopener noreferrer">Оценить бутылку</a>
</header>

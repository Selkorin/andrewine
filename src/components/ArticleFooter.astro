---
interface Props {
  root?: string;
}

const { root = '../' } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="article-site-footer" data-site-chrome="footer">
  <div class="article-site-footer__grid">
    <div class="article-site-footer__brand">
      <a href={root}>ANDREWINE</a>
      <p>Экспертная оценка коллекционного алкоголя и редакционные материалы о редких бутылках.</p>
    </div>
    <div>
      <p class="article-site-footer__title">Разделы</p>
      <nav aria-label="Разделы алкоголя">
        <a href={`${root}buy_wine/`}>Вино</a><a href={`${root}buy_whisky/`}>Виски</a><a href={`${root}buy_cognac/`}>Коньяк</a><a href={`${root}buy_champagne/`}>Шампанское</a>
      </nav>
    </div>
    <div>
      <p class="article-site-footer__title">Компания</p>
      <nav aria-label="Ссылки компании">
        <a href={root}>Главная</a><a href={`${root}articles/`}>Журнал</a><a href="https://t.me/AWONLINE_BOT" rel="noopener noreferrer">Онлайн-оценка</a>
      </nav>
    </div>
  </div>
  <div class="article-site-footer__bottom"><span>© 2014–{year} Andrewine</span><span>18+</span></div>
</footer>

---
import { articles } from '../../data/articles';
import enhancementsCss from '../../styles/enhancements.css?raw';
import OriginalHeader from '../../components/OriginalHeader.astro';
import OriginalFooter from '../../components/OriginalFooter.astro';
import TildaChromeHead from '../../components/TildaChromeHead.astro';

const [featured, ...remainingArticles] = articles;
---
<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Статьи об оценке коллекционного алкоголя | Andrewine</title>
    <meta name="description" content="Практические статьи об оценке коллекционного виски, коньяка, вина и шампанского: бренды, винтажи, состояние и фотографии." />
    <link rel="canonical" href="https://andrewine.ru/articles/" />
    <TildaChromeHead />
    <style is:inline set:html={enhancementsCss} />
  </head>
  <body class="t-body article-page">
    <div id="allrecords" class="t-records" data-tilda-project-id="22260796">
    <OriginalHeader root="../" />
    <main class="article-index article-main">
      <div class="section-rail section-rail--wine" aria-hidden="true"><span>СТАТЬИ</span><small>ANDREWINE</small></div>
      <div class="article-index__intro">
        <a class="article-back" href="../">← На главную</a>
        <div class="magazine-kicker"><span>Журнал Andrewine</span><span>Выпуск 01</span></div>
        <h1>Истории редких бутылок и культура коллекционирования</h1>
        <p class="article-lead">Марки, винтажи, состояние и происхождение — редакционный взгляд на то, что делает бутылку коллекционной.</p>
      </div>
      <article class="magazine-feature">
        <a class="magazine-feature__media" href={`./${featured.slug}/`}><img src={featured.image} alt={featured.imageAlt} decoding="async" fetchpriority="high" width="1200" height="800" /></a>
        <div class="magazine-feature__copy">
          <p class="editorial__eyebrow">Материал номера · {featured.eyebrow}</p>
          <h2><a href={`./${featured.slug}/`}>{featured.title}</a></h2>
          <p>{featured.description}</p>
          <a class="article-card__link" href={`./${featured.slug}/`}>Читать материал →</a>
        </div>
      </article>
      <div class="magazine-rule"><span>Новые материалы</span></div>
      <div class="editorial__grid magazine-grid">
        {remainingArticles.map((article, index) => (
          <article class="article-card">
            <a class="article-card__media" href={`./${article.slug}/`} tabindex="-1" aria-hidden="true"><img src={article.image} alt="" loading="lazy" decoding="async" width="800" height="600" /></a>
            <div class="article-card__content">
              <p><span>0{index + 2}</span> {article.eyebrow}</p>
              <h2><a href={`./${article.slug}/`}>{article.title}</a></h2>
              <p class="article-card__text">{article.description}</p>
              <a class="article-card__link" href={`./${article.slug}/`}>Читать статью →</a>
            </div>
          </article>
        ))}
      </div>
    </main>
    <OriginalFooter root="../" />
    </div>
  </body>
</html>

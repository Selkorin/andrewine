---
import { articles } from '../../data/articles';
import enhancementsCss from '../../styles/enhancements.css?raw';

export function getStaticPaths() {
  return articles.map(article => ({ params: { slug: article.slug }, props: { article } }));
}

const { article } = Astro.props;
const faq = [
  ['Можно определить точную цену только по фото?', 'По фотографиям определяется предварительный диапазон. Итог зависит от проверки подлинности и фактического состояния бутылки.'],
  ['Какие фотографии нужны?', 'Общий вид спереди и сзади, этикетки крупно, капсула и пробка, уровень напитка, дно, серийные номера и упаковка.'],
  ['Нужно ли очищать старую бутылку?', 'Нет. Не мойте этикетку и не удаляйте следы хранения: неосторожная очистка может снизить коллекционную ценность.'],
];
---
<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{article.title} | Andrewine</title>
    <meta name="description" content={article.description} />
    <link rel="canonical" href={`https://andrewine.ru/articles/${article.slug}/`} />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400..700&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style is:inline set:html={enhancementsCss} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify({ '@context':'https://schema.org', '@type':'Article', headline:article.title, description:article.description, author:{ '@type':'Organization', name:'Andrewine' }, mainEntityOfPage:`https://andrewine.ru/articles/${article.slug}/` })} />
  </head>
  <body class="article-page">
    <main class="article-detail">
      <a class="article-back" href="../">← Все статьи</a>
      <p class="editorial__eyebrow">{article.eyebrow}</p>
      <h1>{article.title}</h1>
      <p class="article-lead">{article.description}</p>
      <div class="article-body">
        <h2>Что проверяют при оценке</h2>
        <p>Коллекционная стоимость складывается не из одного признака. Эксперт сопоставляет конкретный релиз со спросом, проверяет маркировки и оценивает сохранность содержимого и оформления.</p>
        <ul>{article.topics.map(topic => <li>{topic}</li>)}</ul>
        <h2>Состояние бутылки</h2>
        <p>Сфотографируйте уровень напитка, капсулу, пробку, лицевую и оборотную этикетки. Потёртости, следы подтекания и повреждения коробки лучше показать сразу.</p>
        <h2>Как получить предварительное предложение</h2>
        <ol><li>Сделайте фотографии при дневном рассеянном свете.</li><li>Укажите объём, крепость, год или код розлива.</li><li>Расскажите, где и в каком положении хранилась бутылка.</li><li>Отправьте материалы оценщику.</li></ol>
        <aside>Не вскрывайте бутылку и не пытайтесь восстановить этикетку самостоятельно.</aside>
        <h2>Частые вопросы</h2>
        {faq.map(([q,a]) => <details class="faq__item"><summary>{q}<span>+</span></summary><p>{a}</p></details>)}
      </div>
    </main>
  </body>
</html>

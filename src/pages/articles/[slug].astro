---
import { articles } from '../../data/articles';
import enhancementsCss from '../../styles/enhancements.css?raw';
import ArticleHeader from '../../components/ArticleHeader.astro';
import ArticleFooter from '../../components/ArticleFooter.astro';

export function getStaticPaths() {
  return articles.map(article => ({ params: { slug: article.slug }, props: { article } }));
}

const { article } = Astro.props;
const articleNumber = String(articles.findIndex(item => item.slug === article.slug) + 1).padStart(2, '0');
const faq = [
  ['Можно определить точную цену только по фото?', 'По фотографиям определяется предварительный диапазон. Итог зависит от проверки подлинности и фактического состояния бутылки.'],
  ['Какие фотографии нужны?', 'Общий вид спереди и сзади, этикетки крупно, капсула и пробка, уровень напитка, дно, серийные номера и упаковка.'],
  ['Нужно ли очищать старую бутылку?', 'Нет. Не мойте этикетку и не удаляйте следы хранения: неосторожная очистка может снизить коллекционную ценность.'],
];
---
<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{article.title} | Andrewine</title>
    <meta name="description" content={article.description} />
    <link rel="canonical" href={`https://andrewine.ru/articles/${article.slug}/`} />
    <style is:inline set:html={enhancementsCss} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify({ '@context':'https://schema.org', '@type':'Article', headline:article.title, description:article.description, image:article.image, author:{ '@type':'Organization', name:'Andrewine' }, publisher:{ '@type':'Organization', name:'Andrewine' }, mainEntityOfPage:`https://andrewine.ru/articles/${article.slug}/` })} />
  </head>
  <body class="article-page">
    <ArticleHeader root="../../" />
    <main>
      <section class="article-mast">
        <div class="section-rail section-rail--light" aria-hidden="true"><span>ЖУРНАЛ</span><small>ANDREWINE</small></div>
        <div class="article-cover">
          <div class="article-cover__copy">
            <a class="article-back" href="../">← Все статьи</a>
            <div class="magazine-kicker magazine-kicker--light"><span>Журнал Andrewine</span><span>Материал {articleNumber}</span></div>
            <p class="editorial__eyebrow">{article.eyebrow}</p>
            <h1>{article.title}</h1>
            <p class="article-lead">{article.description}</p>
          </div>
          <figure class="article-cover__media">
            <img src={article.image} alt={article.imageAlt} width="1200" height="800" decoding="async" fetchpriority="high" />
            <figcaption>Фото: <a href={article.imagePage} rel="noopener noreferrer">{article.imageCredit}</a></figcaption>
          </figure>
        </div>
      </section>
      <article class="article-detail">
        <aside class="article-toc" aria-label="Содержание статьи">
          <p>В материале</p>
          <ol>{article.sections.map((section, index) => <li><a href={`#section-${index + 1}`}>{section.title}</a></li>)}</ol>
        </aside>
        <div class="article-body article-body--magazine">
          <p class="article-intro">{article.intro}</p>
          {article.sections.map((section, index) => (
            <section id={`section-${index + 1}`}>
              <p class="article-section-number">0{index + 1}</p>
              <h2>{section.title}</h2>
              {section.paragraphs.map(paragraph => <p>{paragraph}</p>)}
            </section>
          ))}
          <section class="article-checklist">
            <p class="editorial__eyebrow">Чек-лист</p>
            <h2>Что подготовить для оценки</h2>
            <ul>{article.checklist.map(item => <li>{item}</li>)}</ul>
          </section>
          <aside>{article.note}</aside>
        <h2>Частые вопросы</h2>
        {faq.map(([q,a]) => <details class="faq__item"><summary>{q}<span>+</span></summary><p>{a}</p></details>)}
      </div>
      </article>
    </main>
    <ArticleFooter root="../../" />
  </body>
</html>
